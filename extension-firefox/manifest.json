{
  "manifest_version": 3,
  "name": "BikeDetour",
  "version": "0.1.0",
  "description": "Overlay cycling construction works and road closures on route planner maps so you can detour around them. https://github.com/khendrickx/bikedetour",

  "browser_specific_settings": {
    "gecko": {
      "id": "bikedetour@cycling-construction-planning",
      "strict_min_version": "128.0",
      "update_url": "https://kilianhendrickx.be/bikedetour/updates.json",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "permissions": ["storage"],
  "host_permissions": [
    "https://www.komoot.com/*",
    "https://geo.api.vlaanderen.be/*",
    "https://data.mobility.brussels/*",
    "https://opendata.ndw.nu/*",
    "https://www.cita.lu/*"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["https://www.komoot.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["adapters/KomootAdapter.js", "injected.js"],
      "matches": ["https://www.komoot.com/*"]
    }
  ],

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "BikeDetour",
    "default_icon": "icons/icon.svg"
  }
}
